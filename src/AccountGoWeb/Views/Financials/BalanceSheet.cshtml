@model ICollection<AccountGoWeb.Models.BalanceSheet>
@{
  ViewBag.Title = "BalanceSheet";
  Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (Model != null)
{
  <div class="text-center">
  <h3>Balance Sheet</h3>
</div>
  <div>
  <table class="table">
    <tr class="report-header-row">
      <td>Account Code</td>
      <td>Account Name</td>
      <td class="text-right">Amount</td>
    </tr>
        @foreach (var asset in Model.Where(a => a.AccountClassId == 1))
        {
            <tr>
                <td>@Html.ActionLink((string)string.Format("{0}", asset.AccountCode), "account", new { id = asset.AccountId })</td>
                <td>@asset.AccountName</td>
                <td class="text-right report-amount">@asset.Amount</td>
            </tr>
        }
    <tr class="report-header-row">
      <td colspan="2">Total Assets</td>
      <td class="report-total-row text-right">@Model.Where(a => a.AccountClassId == 1).Sum(a => a.Amount)</td>
    </tr>
  </table>
</div>
  <div class="clear-both">
  <table class="table">
    <tr class="report-header-row">
      <td>Account Code</td>
      <td>Account Namce</td>
      <td class="text-right">Amount</td>
    </tr>
    @foreach (var liability in Model.Where(a => a.AccountClassId == 2))
      {
        <tr>
          <td>@Html.ActionLink((string)string.Format("{0}", liability.AccountCode), "account", new
              {
                id =
                 liability.AccountId
              })</td>
          <td>@liability.AccountName</td>
          <td class="text-right report-amount">@liability.Amount</td>
        </tr>
      }
      <tr class="report-header-row">
        <td colspan="2">Total Liabilities</td>
        <td class="report-total-row text-right">@Model.Where(a => a.AccountClassId == 2).Sum(a => a.Amount)</td>
      </tr>
    </table>
  </div>
  <div class="clear-both">
  <table class="table">
    <tr class="report-header-row">
      <td>Account Code</td>
      <td>Account Namce</td>
      <td class="text-right">Amount</td>
    </tr>
    @foreach (var equity in Model.Where(a => a.AccountClassId == 3))
      {
        <tr>
          <td>@Html.ActionLink((string)string.Format("{0}", equity.AccountCode), "account", new { id = equity.AccountId })
          </td>
          <td>@equity.AccountName</td>
          <td class="text-right report-amount">@equity.Amount</td>
        </tr>
      }
      <tr class="report-header-row">
        <td colspan="2">Total Equities</td>
        <td class="report-total-row text-right">@Model.Where(a => a.AccountClassId == 3).Sum(a => a.Amount)</td>
      </tr>
    </table>
  </div>
}

else
{
  <p>Error fetching data.</p>
}