@model ICollection<AccountGoWeb.Models.TrialBalance>
@{
    ViewBag.Title = "TrialBalance";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="text-center">
    <h3>
        <label>Trial Balance as at</label>
        <br />
        @DateTime.Now.ToShortDateString()
    </h3>
</div>
<div>
    <table class="table">
        <tr class="report-header-row">
            <td>Account Code</td>
            <td>Account Name</td>
            <td class="text-right report-amount">Debit</td>
            <td class="text-right report-amount">Credit</td>
        </tr>
        @foreach (var account in Model)
        {
            <tr>
                <td>@Html.ActionLink((string)string.Format("{0}", account.AccountCode), "account", new { id = account.AccountId })</td>
                <td>@account.AccountName</td>
                <td class="text-right report-amount">@account.Debit</td>
                <td class="text-right report-amount">@account.Credit</td>
            </tr>
        }
        <tr class="report-total-row text-right">
            <td></td>
            <td>Total</td>
            <td>@Model.Sum(m => m.Debit)</td>
            <td>@Model.Sum(m => m.Credit)</td>
        </tr>
    </table>
</div>