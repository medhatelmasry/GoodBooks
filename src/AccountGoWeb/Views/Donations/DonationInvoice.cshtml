@model Dto.Donations.DonationInvoice
@using System.Globalization
<style>
    tr th {
        color: #fff;
    }

    tr td {
        color: #fff;
    }

    div.row {
        color: #fff;
        margin-bottom: 3px;
    }
</style>

<form action="~/Donations/DonationInvoice" method="post">
    <div id="divDonationInvoiceCard" class="col-md-11">
        @Html.HiddenFor(m => m.Id)
        <div class="card">
            <div class="card-body show row" id="general">
                <div class="col-sm-10">
                    @* ID *@
                    <div class="row">
                        <input asp-for="No" type="hidden" value="@Model.No" />
                        <div class="col-sm-5">ID</div>
                        <div class="col-sm-7">@Model.Id</div>
                    </div>
                    @* Donor Name *@
                    <div class="row">
                        <div class="col-sm-5" id="donor-name">Donor Name</div>
                        <div class="col-sm-7">
                            <select class="form-control" asp-for="DonorId" asp-items="@ViewBag.Customers"
                                id="optDonor"></select>
                            <span asp-validation-for="DonorId" class="text-danger"></span>
                            @Html.HiddenFor(m => m.DonorId)
                        </div>
                    </div>
                    @* Donation Date *@
                    <div class="row">
                        <div class="col-sm-5">Donation Date</div>
                        <div class="col-sm-7">
                            <input class="form-control pull-right" type="date" asp-for="DonationDate">
                        </div>
                    </div>
                    @* Purpose *@
                    <div class="row">
                        <div class="col-sm-5">Purpose</div>
                        <div class="col-sm-7">
                            <input class="form-control" asp-for="Purpose" type="text"
                                placeholder="Donation purpose..." />
                        </div>
                    </div>
                    @* Reference No *@
                    <div class="row">
                        <div class="col-sm-5">Reference No</div>
                        <div class="col-sm-7">
                            <input class="form-control" asp-for="ReferenceNo" type="text"
                                placeholder="Reference number..." />
                        </div>
                    </div>
                    @* Tax Receipt *@
                    <div class="row">
                        <div class="col-sm-5">Tax Receipt No</div>
                        <div class="col-sm-7">
                            <input class="form-control" asp-for="TaxReceiptNo" type="text"
                                placeholder="Tax receipt number..." />
                        </div>
                    </div>
                    @* Tax Receipt Issued *@
                    <div class="row">
                        <div class="col-sm-5">Tax Receipt Issued</div>
                        <div class="col-sm-7">
                            <input class="form-check" asp-for="IsTaxReceiptIssued" type="checkbox" />
                        </div>
                    </div>
                    @* Posted *@
                    <div class="row">
                        <div class="col-sm-5">Posted</div>
                        <div class="col-sm-7">
                            <input class="form-check" asp-for="Posted" type="checkbox" />
                        </div>
                    </div>
                    @* Total Amount *@
                    <div class="row">
                        <div class="col-sm-5">Total Amount</div>
                        <div class="col-sm-7">@String.Format("{0:F2}", ViewBag.TotalAmount)</div>
                    </div>
                </div>
            </div>

            @* Table *@
            <table class="table">
                <thead>
                    <th>Item</th>
                    <th>Quantity</th>
                    <th>Amount</th>
                <th>Unit</th>
                    <th>Notes</th>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.DonationInvoiceLines!.Count; i++)
                    {
                        <tr>
                            <td>
                                <input asp-for="@Model.DonationInvoiceLines[i].Id" type="hidden" />
                                <select class="form-control" asp-for="@Model.DonationInvoiceLines[i].ItemId"
                                    asp-items="@ViewBag.Items" id="optItem"></select>
                                <span asp-validation-for="@Model.DonationInvoiceLines[i].ItemId" class="text-danger"></span>
                            </td>
                            <td>
                                <input class="form-control" asp-for="@Model.DonationInvoiceLines[i].Quantity" type="text"
                                    placeholder="0.0 ..." />
                                <span asp-validation-for="@Model.DonationInvoiceLines[i].Quantity"
                                    class="text-danger"></span>
                            </td>
                            <td>
                                <input class="form-control" asp-for="@Model.DonationInvoiceLines[i].Amount" type="text"
                                    placeholder="0.0 ..." />
                                <span asp-validation-for="@Model.DonationInvoiceLines[i].Amount" class="text-danger"></span>
                            </td>
                            <td>
                                <select class="form-control" asp-for="@Model.DonationInvoiceLines[i].MeasurementId"
                                    asp-items="@ViewBag.Measurements" id="optMeasurement"></select>
                                <span asp-validation-for="@Model.DonationInvoiceLines[i].MeasurementId"
                                    class="text-danger"></span>
                            </td>
                            <td>
                                <input class="form-control" asp-for="@Model.DonationInvoiceLines[i].Notes" type="text"
                                    placeholder="Notes..." />
                                <span asp-validation-for="@Model.DonationInvoiceLines[i].Notes" class="text-danger"></span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-sm-9">
        <input id="btnSave" class="btn btn-sm btn-primary btn-flat pull-left" type="submit" value="Save" />
        <a href="~/donations/donationinvoices" class="btn btn-sm btn-default btn-flat pull-left">Close</a>
    </div>
</form>

@section scripts {
    <script src="~/js/custom.js" type="text/javascript"></script>
    <script>
        function onClickEditButton() {
            document.getElementById("linkEdit").className = document.getElementById("linkEdit").className + " disabledControl";
            document.getElementById("btnSave").className = "btn btn-sm btn-primary btn-flat pull-left";
            setFormEnabled("divDonationInvoiceCard");
        }
    </script>
}
