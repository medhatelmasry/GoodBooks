@model Dto.Donations.DonationInvoice

<style>
    tr,
    td,
    div.row {
        color: white;
    }
</style>

<form action="~/Donations/AddDonationInvoice" method="post" id="donationInvoiceForm">
    <div class="col-sm-10">
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true)
        @Html.HiddenFor(m => m.No)
        <div class="card">
            <div class="card-body">
                @* Donor *@
                <div class="row">
                    <div class="col-sm-3">Donor</div>
                    <div class="col-sm-8">
                        <select class="form-control" asp-for="DonorId" asp-items="@ViewBag.Customers"
                            id="optDonor"></select>
                        <span asp-validation-for="DonorId" class="text-danger"></span>
                    </div>
                </div>
                @* Donation Date *@
                <div class="row">
                    <div class="col-sm-3">Donation Date</div>
                    <div class="col-sm-8">
                        <input class="form-control pull-right" type="date" asp-for="DonationDate">
                        <span asp-validation-for="DonationDate" class="text-danger"></span>
                    </div>
                </div>
                @* Purpose *@
                <div class="row">
                    <div class="col-sm-3">Purpose</div>
                    <div class="col-sm-8">
                        <input class="form-control" asp-for="Purpose" type="text" placeholder="Donation purpose..." />
                        <span asp-validation-for="Purpose" class="text-danger"></span>
                    </div>
                </div>
                @* Reference No *@
                <div class="row">
                    <div class="col-sm-3">Reference No</div>
                    <div class="col-sm-8">
                        <input class="form-control" asp-for="ReferenceNo" type="text"
                            placeholder="Reference number..." />
                        <span asp-validation-for="ReferenceNo" class="text-danger"></span>
                    </div>
                </div>
                @* Tax Receipt *@
                <div class="row">
                    <div class="col-sm-3">Tax Receipt Issued</div>
                    <div class="col-sm-8">
                        <input class="form-check" asp-for="IsTaxReceiptIssued" type="checkbox" id="chkTaxReceipt" />
                        <span asp-validation-for="IsTaxReceiptIssued" class="text-danger"></span>
                    </div>
                </div>
                @* Posted *@
                <div class="row">
                    <div class="col-sm-3">Posted</div>
                    <div class="col-sm-8">
                        <input class="form-check" asp-for="Posted" type="checkbox" id="chkPosted" />
                        <span asp-validation-for="Posted" class="text-danger"></span>
                    </div>
                </div>

                <table class="table">
                    <thead>
                        <th>Item</th>
                        <th>Quantity</th>
                        <th>Amount</th>
                        <th>Measurement</th>
                        <th>Notes</th>
                    </thead>
                    <tbody id="invoiceLines">
                        @for (int i = 0; i < Model.DonationInvoiceLines!.Count; i++)
                        {
                            <tr>
                                <td>
                                    <select class="form-control item-select" asp-for="@Model.DonationInvoiceLines[i].ItemId"
                                        asp-items="@ViewBag.Items" data-index="@i"></select>
                                    <span asp-validation-for="@Model.DonationInvoiceLines[i].ItemId"
                                        class="text-danger"></span>
                                </td>
                                <td>
                                    <input class="form-control quantity-input"
                                        asp-for="@Model.DonationInvoiceLines[i].Quantity" type="text" placeholder="0.0 ..."
                                        data-index="@i" />
                                    <span asp-validation-for="@Model.DonationInvoiceLines[i].Quantity"
                                        class="text-danger"></span>
                                </td>
                                <td>
                                    <input class="form-control amount-input" asp-for="@Model.DonationInvoiceLines[i].Amount"
                                        type="text" placeholder="0.0 ..." data-index="@i" />
                                    <span asp-validation-for="@Model.DonationInvoiceLines[i].Amount"
                                        class="text-danger"></span>
                                </td>
                                <td>
                                    <select class="form-control measurement-select"
                                        asp-for="@Model.DonationInvoiceLines[i].MeasurementId"
                                        asp-items="@ViewBag.Measurements" data-index="@i"></select>
                                    <span asp-validation-for="@Model.DonationInvoiceLines[i].MeasurementId"
                                        class="text-danger"></span>
                                </td>
                                <td>
                                    <input class="form-control notes-input" asp-for="@Model.DonationInvoiceLines[i].Notes"
                                        type="text" placeholder="Notes..." data-index="@i" />
                                    <span asp-validation-for="@Model.DonationInvoiceLines[i].Notes"
                                        class="text-danger"></span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-9">
        <input id="btnSave" class="btn btn-sm btn-primary btn-flat pull-left" type="submit" value="Save" />
        <a href="~/donations/donationinvoices" class="btn btn-sm btn-default btn-flat pull-left">Close</a>
    </div>
</form>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        console.log('Donation Invoice page loaded. Adding event listeners.');

        // Log Donor selection
        document.getElementById('optDonor').addEventListener('change', function () {
            console.log('Donor selected:', this.value);
        });

        // Log Tax Receipt checkbox
        document.getElementById('chkTaxReceipt').addEventListener('change', function () {
            console.log('Tax Receipt checkbox state:', this.checked);
        });

        // Log Posted checkbox
        document.getElementById('chkPosted').addEventListener('change', function () {
            console.log('Posted checkbox state:', this.checked);
        });

        // Log table row changes
        const invoiceTable = document.getElementById('invoiceLines');
        invoiceTable.addEventListener('input', function (e) {
            const target = e.target;
            const index = target.getAttribute('data-index');

            if (target.classList.contains('quantity-input')) {
                console.log(`Row ${index} Quantity changed to:`, target.value);
            } else if (target.classList.contains('amount-input')) {
                console.log(`Row ${index} Amount changed to:`, target.value);
            } else if (target.classList.contains('notes-input')) {
                console.log(`Row ${index} Notes changed to:`, target.value);
            }
        });

        // Log row selection changes
        invoiceTable.addEventListener('change', function (e) {
            const target = e.target;
            const index = target.getAttribute('data-index');

            if (target.classList.contains('item-select')) {
                console.log(`Row ${index} Item selected:`, target.value);
            } else if (target.classList.contains('measurement-select')) {
                console.log(`Row ${index} Measurement selected:`, target.value);
            }
        });

        // Log form submission
        document.getElementById('donationInvoiceForm').addEventListener('submit', function (e) {
            console.log('Donation Invoice form submitted.');
        });
    });
</script>