@model string

<style>
    .ag-row-selected {
        background-color: darkorange;
        color: white;
        border-color: aqua;
        opacity: 0.9;
    }
</style>

<div>
    <a href="~/donations/adddonationinvoice" class="btn btn-outline-light">
        <i class="fa fa-plus"></i>
        New Donation Invoice
    </a>
    <a href="~/donations/donationinvoice" id="linkEditInvoice" class="btn inactiveLink">
        <i class="fa fa-edit"></i>
        Edit
    </a>
    <a href="~/donations/deletedonationinvoice" id="linkDeleteInvoice" class="btn inactiveLink">
        <i class="fa fa-trash"></i>
        Delete
    </a>
</div>
<div>
    <div id="donationinvoices" class="ag-fresh" style="height: 400px;"></div>
</div>

@* Delete Modal*@
<div class="modal" id="deleteDonationInvoice" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete</h5>
                <button aria-label="Close" class="btn-close" data-bs-dismiss="modal" type="button"></button>
            </div>
            <div class="modal-body">
                <p>Do you want to delete this donation invoice?</p>
                <input type="hidden" id="hdnselecteddonationInvoiceId" />
            </div>
            <div class="modal-footer">
                <button class="btn btn-sm btn-primary btn-flat" onclick="deleteDonationInvoice()"
                    type="button">Yes</button>
                <button class="btn btn-sm btn-default btn-flat" data-bs-dismiss="modal" type="button">No</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        var columnDefs = [
            { headerName: "No", field: "no", width: 80 },
            { headerName: "Donor Name", field: "donorName", width: 180 },
            {
                headerName: "Donation Date",
                field: "donationDate",
                width: 120,
                valueFormatter: function (params) {
                    if (params.value) {
                        var date = new Date(params.value);
                        return date.toLocaleDateString();
                    }
                    return '';
                }
            },
            {
                headerName: "Amount",
                field: "amount",
                width: 100,
                valueFormatter: function (params) {
                    return '$' + (params.value || 0).toFixed(2);
                }
            },
            { headerName: "Purpose", field: "purpose", width: 150 },
            { headerName: "Ref No", field: "referenceNo", width: 100 },
            { headerName: "Tax Receipt No", field: "taxReceiptNo", width: 120 },
            {
                headerName: "Tax Receipt Issued", width: 80, cellRenderer: function (val) {
                    if (val.data.isTaxReceiptIssued)
                        return '<input type="checkbox" checked disabled />';
                    return '<input type="checkbox" disabled />';
                }
            },
            {
                headerName: "Posted", width: 80, cellRenderer: function (val) {
                    if (val.data.posted)
                        return '<input type="checkbox" checked disabled />';
                    return '<input type="checkbox" disabled />';
                }
            },
        ];

        var gridOptions = {
            columnDefs: columnDefs,
            rowData: @Html.Raw(Model),
            enableSorting: true,
            rowSelection: 'single',
            onSelectionChanged: onSelectionChanged,
        };

        function onSelectionChanged() {
            var selectedRows = gridOptions.api.getSelectedRows();
            selectedRow = selectedRows[0];
            console.log(selectedRow);

            document.getElementById('linkEditInvoice').setAttribute('href', 'Donations/DonationInvoice?id=' + selectedRow.id);
            document.getElementById('linkEditInvoice').setAttribute('class', 'btn btn-outline-light');

            document.getElementById('linkDeleteInvoice').setAttribute('class', 'btn btn-outline-light');
            document.getElementById('linkDeleteInvoice').setAttribute('data-bs-toggle', 'modal');
            document.getElementById('linkDeleteInvoice').setAttribute('data-bs-target', '#deleteDonationInvoice');
            $("#hdnselecteddonationInvoiceId").val(selectedRow.id);
        }

        document.addEventListener("DOMContentLoaded", function () {
            var eGridDiv = document.querySelector('#donationinvoices');
            new agGrid.Grid(eGridDiv, gridOptions);
        });

        function deleteDonationInvoice() {
            var donationInvoiceId = $("#hdnselecteddonationInvoiceId").val();
            window.location.href = "/donations/deletedonationinvoice?id=" + donationInvoiceId;
        }
    </script>
}