<!DOCTYPE html>
<html lang="en">

<head>
    <base href="~/" />
    <component type="typeof(Microsoft.AspNetCore.Components.Web.HeadOutlet)" render-mode="ServerPrerendered" />
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <meta name="description" content="Good Deed Books - Open Source Accounting System">
    <title>Good Deed Books</title>
    <link rel="icon" type="image/x-icon" href="~/images/favicon.ico">
    <link rel="stylesheet" href="~/GoodBooks.styles.css" asp-append-version="true" />
    
    <!-- Bootstrap 5.3.x CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" 
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" 
          integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" 
          crossorigin="anonymous" referrerpolicy="no-referrer">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/simple-line-icons/2.5.5/css/simple-line-icons.min.css" rel="stylesheet">
    
    <!-- Main styles for this application (theme will be set by JavaScript) -->
    <link id="theme-stylesheet" href="~/css/dark.css" rel="stylesheet">
    <link href="~/css/gdbdark.css" rel="stylesheet">
    <link href="~/css/navbar.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/pace-js@latest/pace-theme-default.min.css" rel="stylesheet">
    <link href="~/css/agw-colors.css" rel="stylesheet">
    <link href="~/css/utilities.css" rel="stylesheet" asp-append-version="true">
    <link href="~/css/theme-toggle.css" rel="stylesheet" asp-append-version="true">
    
    <!-- Page-specific styles -->
    @RenderSection("Styles", required: false)
    
    <!-- Theme Toggle Script (loaded early to prevent flash) -->
    <script src="~/js/theme-toggle.js" asp-append-version="true"></script>

</head>

