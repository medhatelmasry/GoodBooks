@*
@model List<Dto.Auditing.AuditableEntity>
@using AccountGoWeb.Models;

<div class="row">
    <div class="col-12">
        <div class="box">

            <!-- Adding new Auditable Entity -->
            <div class="box-header">
                <a asp-controller="Audit" asp-action="GetEntity" class="btn btn-primary btn-sm">
                    <i class="fas fa-plus"></i> Add New Entity
                </a>
            </div>

            <!-- Auditable Entities List -->
            <div class="box-body">
                <div id="auditableEntities" class="ag-grid-container ag-theme-blue h-400"></div>
            </div>
        </div>
    </div>
</div>

<!-- Javascript for Auditable Entities -->
<script>

    // Define columns for the Auditable Entities grid
    var columnDefs = [
        { headerName: "ID", field: "Id", width: 80 },
        { headerName: "Entity Name", field: "EntityName", width: 200 },
        { headerName: "Enable Audit", field: "EnableAudit", width: 120, 
          cellRenderer: function(params) {
              return params.value ? '<i class="fas fa-check text-success"></i>' : '<i class="fas fa-times text-danger"></i>';
          }
        },
        { 
            // This section appear when new entity is added (edit, attributes, delete).
            headerName: "Actions", 
            width: 280,
            cellRenderer: function(params) {
                return `
                    <a href="/Audit/GetEntity?id=${params.data.Id}" class="btn btn-info btn-sm me-5px">
                        <i class="fas fa-edit"></i> Edit
                    </a>
                    <a href="/Audit/GetAuditableAttributes?entityId=${params.data.Id}" class="btn btn-success btn-sm me-5px">
                        <i class="fas fa-list"></i> Attributes
                    </a>
                    <a href="/Audit/DeleteEntity?id=${params.data.Id}" class="btn btn-danger btn-sm" 
                       onclick="return confirm('Are you sure you want to delete this entity?')">
                        <i class="fas fa-trash"></i> Delete
                    </a>
                `;
            }
        }
    ];

    // Define grid options
    var gridOptions = {
        columnDefs: columnDefs,
        rowData: @Html.Raw(Model.ToJson()),
        rowSelection: 'single',
        enableFilter: true,
        enableColResize: true,
    };

    document.addEventListener("DOMContentLoaded", function() {
        var eGridDiv = document.querySelector('#auditableEntities');
        new agGrid.Grid(eGridDiv, gridOptions);
    });
</script>
*@

@using AccountGoWeb.Components.Pages.Audit
@{
    ViewData["Title"] = "Auditable Entities";
}

<component type="typeof(AuditableEntities)" render-mode="ServerPrerendered" />