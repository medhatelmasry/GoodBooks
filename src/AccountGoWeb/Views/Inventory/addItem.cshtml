@model Dto.Inventory.Item

@* New Blazor Component Implementation *@
@using AccountGoWeb.Components.Pages.Inventory
<component type="typeof(ItemForm)" render-mode="ServerPrerendered" param-ItemId="@Model.Id" />

<style>
    div.row,
    div.card-header {
        color: #fff;
    }

    .alert-danger {
        margin-bottom: 20px;
    }

    .error-list {
        margin: 10px 0;
    }

    .error-list li {
        color: #dc3545;
        list-style-type: none;
        padding: 5px 0;
    }
</style>

 <form action="~/Inventory/AddItem" method="post">
    <div class="col-sm-10">
        @Html.AntiForgeryToken()

<!-- Display validation/error messages -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            <h5 class="alert-heading"><i class="fa fa-exclamation-circle me-2"></i>Errors</h5>
            
            @if (ViewData.ModelState.Keys.Count() > 0)
            {
                <ul class="error-list">
                    @foreach (var modelState in ViewData.ModelState.Values)
                    {
                        @foreach (var error in modelState.Errors)
                        {
                            <li>
                                <strong>•</strong> @error.ErrorMessage
                            </li>
                        }
                    }
                </ul>
            }
        </div>
    }

        @Html.ValidationSummary(true)
        <div class="card">
            <div class="card-body">
                @* Description *@
                <div class="row">
                    <div class="col-sm-3">Name</div>
                    <div class="col-sm-8">
                        <input class="form-control" asp-for="Description" type="text" required />
                        <span asp-validation-for="Description" class="danger"></span>
                    </div>
                </div>
                @* Cost *@
                <div class="row">
                    <div class="col-sm-3">Cost</div>
                    <div class="col-sm-8">
                        <input class="form-control" asp-for="Cost" type="number" />
                        <span asp-validation-for="Cost" class="danger"></span>
                    </div>
                </div>
                @* Item Category *@
                <div class="row">
                    <div class="col-sm-3">Item Category</div>
                    <div class="col-sm-8">
                        <select class="form-control" asp-for="ItemCategoryId" asp-items="ViewBag.ItemCategories"></select>
                        <span asp-validation-for="ItemCategoryId" class="danger"></span>
                    </div>
                </div>
                @* Smallest Measurement *@
                <div class="row">
                <div class="col-sm-3">Smallest Unit</div>
                    <div class="col-sm-8">
                        <select class="form-control" asp-for="SmallestMeasurementId" asp-items="ViewBag.Measurements"></select>
                        <span asp-validation-for="SmallestMeasurementId" class="danger"></span>
                    </div>
                </div>
                @* Purchase Measurement *@
                <div class="row">
                <div class="col-sm-3">Purchase Unit</div>
                    <div class="col-sm-8">
                        <select class="form-control" asp-for="PurchaseMeasurementId" asp-items="ViewBag.Measurements"></select>
                        <span asp-validation-for="PurchaseMeasurementId" class="danger"></span>
                    </div>
                </div>
                @* Item Tax Group *@
                <div class="row">
                    <div class="col-sm-3">Item Tax Group</div>
                    <div class="col-sm-8">
                        <select class="form-control" asp-for="ItemTaxGroupId" asp-items="ViewBag.ItemTaxGroups"></select>
                        <span asp-validation-for="ItemTaxGroupId" class="danger"></span>
                    </div>
                </div>
                @* Preferred Vendor *@
                <div class="row">
                    <div class="col-sm-3">Preferred Vendor</div>
                    <div class="col-sm-8">
                        <select class="form-control" asp-for="PreferredVendorId" asp-items="ViewBag.PreferredVendorId"></select>
                        <span asp-validation-for="PreferredVendorId" class="danger"></span>
                    </div>
                </div>
                @* Sales Account *@
                <div class="row">
                    <div class="col-sm-3">Sales Account</div>
                    <div class="col-sm-8">
                        <select class="form-control" asp-for="SalesAccountId" asp-items="ViewBag.Accounts"></select>
                        <span asp-validation-for="SalesAccountId" class="danger"></span>
                    </div>
                </div>
                @* Inventory Account *@
                <div class="row">
                    <div class="col-sm-3">Inventory Account</div>
                    <div class="col-sm-8">
                        <select class="form-control" asp-for="InventoryAccountId" asp-items="ViewBag.Accounts"></select>
                        <span asp-validation-for="InventoryAccountId" class="danger"></span>
                    </div>
                </div>
                @* Cost of Goods Account *@
                <div class="row">
                    <div class="col-sm-3">Cost of Goods Account</div>
                    <div class="col-sm-8">
                        <select class="form-control" asp-for="CostOfGoodsSoldAccountId" asp-items="ViewBag.Accounts"></select>
                        <span asp-validation-for="CostOfGoodsSoldAccountId" class="danger"></span>
                    </div>
                </div>
                @* Inventory Adjustment Account *@
                <div class="row">
                    <div class="col-sm-3">Inventory Adjustment Account</div>
                    <div class="col-sm-8">
                        <select class="form-control" asp-for="InventoryAdjustmentAccountId" asp-items="ViewBag.Accounts"></select>
                        <span asp-validation-for="InventoryAdjustmentAccountId" class="danger"></span>
                    </div>
                </div>
                @* Code *@
                <div class="row">
                    <div class="col-sm-3">Code</div>
                    <div class="col-sm-8">
                        <input class="form-control" asp-for="Code" type="text" required />
                        <span asp-validation-for="Code" class="danger"></span>
                    </div>
                </div>
                @* Price *@
                <div class="row">
                    <div class="col-sm-3">Price</div>
                    <div class="col-sm-8">
                        <input class="form-control" asp-for="Price" type="number" />
                        <span asp-validation-for="Price" class="danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-9">
        <input id="btnSave" class="btn btn-sm btn-primary btn-flat pull-left" type="submit" value="Save" />
        <a href="~/Inventory" class="btn btn-sm btn-default btn-flat pull-left">Close</a>
    </div>
 </form>
