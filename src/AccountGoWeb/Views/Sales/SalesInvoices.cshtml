@model string

@using Newtonsoft.Json
@{
    var invoicesJson = Model ?? "[]";
    var invoices = JsonConvert.DeserializeObject<List<dynamic>>(invoicesJson) ?? new List<dynamic>();
}

<style>
    .salesInvoicesTable {
        width: 100%;
        border-collapse: collapse;
        background: transparent;
        color: white; /* text visible on dark page */
    }
    .salesInvoicesTable th, .salesInvoicesTable td {
        padding: 8px;
        text-align: left;
        border: none; /* no borders */
    }
    .salesInvoiceRow:hover {
        background-color: rgba(255,255,255,0.1); 
        cursor: pointer;
    }
</style>

<div>
    <a href="~/Sales/SalesInvoice" class="btn">
        <i class="fa fa-plus"></i>
        New Invoice
    </a>
    <a href="javascript:void(0)" id="linkEditInvoice" class="btn inactiveLink">
        <i class="fa fa-edit"></i>
        Edit
    </a>
    <a href="javascript:void(0)" id="linkDeleteInvoice" class="btn inactiveLink">
        <i class="fa fa-trash"></i>
        Delete
    </a>
</div>

<div class="mt-3">
    <table class="salesInvoicesTable">
        <thead>
            <tr>
                <th>No</th>
                <th>Customer Name</th>
                <th>Invoiced Date</th>
                <th>Amount</th>
                <th>Allocated</th>
                <th>Remaining</th>
                <th>Ref no</th>
                <th>Posted</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var invoice in invoices)
            {
                var id = invoice.id;
                var amount = (decimal?)invoice.amount ?? 0;
                var allocated = (decimal?)invoice.totalAllocatedAmount ?? 0;
                var remaining = amount - allocated;
                var posted = (bool?)invoice.posted ?? false;
                var invoiceDate = (DateTime?)invoice.invoiceDate;

                <tr class="salesInvoiceRow" onclick="onRowSelected(this, '@id')">
                    <td>@invoice.no</td>
                    <td>@invoice.customerName</td>
                    <td>@(invoiceDate.HasValue ? invoiceDate.Value.ToString("yyyy-MM-dd") : "")</td>
                    <td>@amount.ToString("N2")</td>
                    <td>@allocated.ToString("N2")</td>
                    <td>@remaining.ToString("N2")</td>
                    <td>@invoice.referenceNo</td>
                    <td>
                        <input type="checkbox" @(posted ? "checked" : "") disabled />
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@* Delete Modal *@
<div class="modal" id="deleteSalesInvoice" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-white">
            <div class="modal-header">
                <h5 class="modal-title">Delete</h5>
                <button aria-label="Close" class="btn-close btn-close-white" data-bs-dismiss="modal" type="button"></button>
            </div>
            <div class="modal-body">
                <p>Do you want to delete it?</p>
                <input type="hidden" id="hdnselectedsalesInvoiceId" />
            </div>
            <div class="modal-footer">
                <button class="btn btn-sm btn-danger btn-flat" onclick="deleteSalesInvoice()"
                    type="button">Yes</button>
                <button class="btn btn-sm btn-secondary btn-flat" data-bs-dismiss="modal" type="button">No</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        function onRowSelected(row, id) {
            // Remove table-active from all rows
            var rows = document.querySelectorAll('.salesInvoiceRow');
            rows.forEach(r => r.classList.remove('table-active'));

            // Add to current row
            row.classList.add('table-active');

            // Update buttons
            var linkEdit = document.getElementById('linkEditInvoice');
            linkEdit.setAttribute('href', '@Url.Content("~/Sales/SalesInvoice?id=")' + id);
            linkEdit.classList.remove('inactiveLink');
            linkEdit.classList.add('btn-outline-light');

            var linkDelete = document.getElementById('linkDeleteInvoice');
            linkDelete.classList.remove('inactiveLink');
            linkDelete.classList.add('btn-outline-light');
            linkDelete.setAttribute('data-bs-toggle', 'modal');
            linkDelete.setAttribute('data-bs-target', '#deleteSalesInvoice');

            document.getElementById('hdnselectedsalesInvoiceId').value = id;
        }

        function deleteSalesInvoice() {
            var salesInvoiceId = document.getElementById('hdnselectedsalesInvoiceId').value;
            location.href = '@Url.Action("DeleteSalesInvoice", "Sales")?id=' + salesInvoiceId;
        }
    </script>
}
