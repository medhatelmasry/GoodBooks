@using System.Text.Json
@using System.Text.Json.Serialization
@using AccountGoWeb.Models
@using AccountGoWeb.Models.Sales
@using Microsoft.AspNetCore.Components

<style>
    label,
    h5 {
        color: var(--bs-white, #fff) !important;
    }

    div.row {
        color: var(--bs-white, #fff);
    }
</style>

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col">
            <h2>Customer Payment</h2>
        </div>
        <div class="col text-end">
            @if (!isEditing)
            {
                <button type="button" class="btn btn-primary btn-sm me-2" @onclick="EnableEdit">
                    <i class="fas fa-edit"></i>
                    Edit
                </button>
            }
            else
            {
                <button type="button" class="btn btn-secondary btn-sm me-2" @onclick="CancelEdit">
                    <i class="fas fa-times"></i>
                    Cancel
                </button>
            }
            <a href="/Sales/CustomerPayments" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-left"></i>
                Back to Customer Payments
            </a>
        </div>
    </div>

    @if (loading)
    {
        <p><em>Loading payment...</em></p>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            <strong>Error:</strong> @errorMessage
        </div>
    }
    else
    {
        <form @onsubmit="HandleSubmit">
            <div class="col-sm-8">
                <div class="card">
                    <div class="card-body">
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Payment ID</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control form-control-themed" value="@receiptId" readonly />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Payment No</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control form-control-themed" @bind="receiptNo" readonly />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Received From</label>
                            <div class="col-sm-9">
                                <select class="form-control form-control-themed" @onchange="OnCustomerChanged" disabled="@(!isEditing)">
                                    <option value="">-- Select Customer --</option>
                                    @foreach (var customer in customers)
                                    {
                                        <option value="@customer.Value" selected="@(customerId.ToString() == customer.Value)">
                                            @customer.Text
                                        </option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Date</label>
                            <div class="col-sm-9">
                                <input type="date" class="form-control form-control-themed" @bind="receiptDate"
                                    readonly="@(!isEditing)" />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Payment Amount</label>
                            <div class="col-sm-9">
                                <input type="number" step="0.01" class="form-control form-control-themed" @bind="amount"
                                    placeholder="0.0" readonly="@(!isEditing)" />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Reference #</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control form-control-themed" @bind="referenceNo"
                                    readonly="@(!isEditing)" />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Payment Method</label>
                            <div class="col-sm-9">
                                <select class="form-control form-control-themed" @bind="paymentMethod"
                                    disabled="@(!isEditing)">
                                    <option value="">-- Select Method --</option>
                                    @foreach (var method in paymentMethods)
                                    {
                                        <option value="@method">@method</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Deposit To</label>
                            <div class="col-sm-9">
                                <select class="form-control form-control-themed" @bind="accountToDebitId"
                                    disabled="@(!isEditing)">
                                    <option value="">-- Select Bank --</option>
                                    @foreach (var account in debitAccounts)
                                    {
                                        <option value="@account.Value"
                                            selected="@(accountToDebitId.ToString() == account.Value)">
                                            @account.Text
                                        </option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Memo</label>
                            <div class="col-sm-9">
                                <textarea class="form-control form-control-themed" @bind="memo" rows="2"
                                    readonly="@(!isEditing)"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                @if (isEditing)
                {
                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="fas fa-save"></i>
                            Save
                        </button>
                        <button type="button" class="btn btn-secondary btn-sm ms-2" @onclick="CancelEdit">
                            <i class="fas fa-times"></i>
                            Cancel
                        </button>
                    </div>
                }
            </div>
        </form>
    }
</div>

@code {
    private bool loading = true;
    private bool isEditing = false;
    private string errorMessage = "";
    private int receiptId = 0;
    private string receiptNo = "";
    private int customerId = 0;
    private int originalCustomerId = 0;
    private DateTime receiptDate = DateTime.Now;
    private DateTime originalReceiptDate = DateTime.Now;
    private int accountToDebitId = 0;
    private int originalAccountToDebitId = 0;
    private int accountToCreditId = 0; // silently populated from customer prepayment
    private decimal amount = 0;
    private decimal originalAmount = 0;
    private string referenceNo = "";
    private string originalReferenceNo = "";
    private string paymentMethod = "";
    private string originalPaymentMethod = "";
    private string memo = "";
    private string originalMemo = "";

    private readonly List<string> paymentMethods = new()
    {
        "Cash",
        "Cheque",
        "Credit Card",
        "Debit Card",
        "E-Transfer"
    };

    private List<(string Text, string Value)> customers = new();
    private List<(string Text, string Value)> debitAccounts = new();
    private Dictionary<int, int> customerAdvanceAccounts = new();

    [SupplyParameterFromQuery(Name = "id")]
    public int Id { get; set; }

    [Inject]
    private IHttpClientFactory ClientFactory { get; set; } = null!;

    [Inject]
    private NavigationManager Navigation { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            string apiurl = System.Environment.GetEnvironmentVariable("APIURL") ?? "http://localhost:8001/api/";
            var client = ClientFactory.CreateClient();
            client.Timeout = TimeSpan.FromSeconds(60);

            // Load customers (+ their prepayment accounts)
            var customersResponse = await client.GetAsync($"{apiurl}sales/customers");
            if (customersResponse.IsSuccessStatusCode)
            {
                var json = await customersResponse.Content.ReadAsStringAsync();
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var customersData = JsonSerializer.Deserialize<List<JsonElement>>(json, options);
                if (customersData != null)
                {
                    foreach (var customer in customersData)
                    {
                        var id = GetJsonPropertyString(customer, "id");
                        var name = GetJsonPropertyString(customer, "name");
                        var prepaymentAccountId = GetJsonPropertyString(customer, "prepaymentAccountId");
                        customers.Add((name ?? "Unknown", id));

                        if (int.TryParse(id, out var cid) && int.TryParse(prepaymentAccountId, out var accId))
                        {
                            customerAdvanceAccounts[cid] = accId;
                        }
                    }
                }
            }

            // Load cash/bank accounts (Deposit To)
            var debitResponse = await client.GetAsync($"{apiurl}financials/CashBanks");
            if (debitResponse.IsSuccessStatusCode)
            {
                var json = await debitResponse.Content.ReadAsStringAsync();
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var accountsData = JsonSerializer.Deserialize<List<JsonElement>>(json, options);
                if (accountsData != null)
                {
                    foreach (var account in accountsData)
                    {
                        var id = GetJsonPropertyString(account, "id");
                        var name = GetJsonPropertyString(account, "name");
                        debitAccounts.Add((name ?? "Unknown", id));
                    }
                }
            }

            // Load payment if editing
            if (Id > 0)
            {
                await LoadPayment();
            }

            loading = false;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load form data: {ex.Message}";
            loading = false;
        }
    }

    private async Task LoadPayment()
    {
        try
        {
            string apiurl = System.Environment.GetEnvironmentVariable("APIURL") ?? "http://localhost:8001/api/";
            var client = ClientFactory.CreateClient();
            var response = await client.GetAsync($"{apiurl}sales/salesreceipt?id={Id}");

            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var receiptData = JsonSerializer.Deserialize<JsonElement>(json, options);

                if (receiptData.ValueKind == JsonValueKind.Object)
                {
                    receiptId = GetJsonInt(receiptData, "id") ?? 0;
                    receiptNo = GetJsonPropertyString(receiptData, "receiptNo");
                    customerId = GetJsonInt(receiptData, "customerId") ?? 0;
                    accountToDebitId = GetJsonInt(receiptData, "accountToDebitId") ?? 0;
                    accountToCreditId = GetJsonInt(receiptData, "accountToCreditId") ?? 0;
                    amount = GetJsonDecimal(receiptData, "amount") ?? 0;
                    referenceNo = GetJsonPropertyString(receiptData, "referenceNo");
                    paymentMethod = GetJsonPropertyString(receiptData, "paymentMethod");
                    memo = GetJsonPropertyString(receiptData, "memo");

                    // If credit account missing, auto-populate from customer's prepayment account
                    if (accountToCreditId == 0 && customerId > 0 && customerAdvanceAccounts.TryGetValue(customerId, out var advanceAccountId))
                    {
                        accountToCreditId = advanceAccountId;
                    }

                    if (receiptData.TryGetProperty("receiptDate", out var dateElem)
                        && DateTime.TryParse(dateElem.GetString(), out var date))
                    {
                        receiptDate = date;
                    }

                    // Store originals for cancel
                    originalCustomerId = customerId;
                    originalReceiptDate = receiptDate;
                    originalAccountToDebitId = accountToDebitId;
                    originalAmount = amount;
                    originalReferenceNo = referenceNo;
                    originalPaymentMethod = paymentMethod;
                    originalMemo = memo;
                }
            }
            else
            {
                errorMessage = $"Failed to load payment. Status: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading payment: {ex.Message}";
        }
    }

    private void OnCustomerChanged(ChangeEventArgs e)
    {
        if (e.Value == null || string.IsNullOrEmpty(e.Value.ToString()))
        {
            customerId = 0;
            accountToCreditId = 0;
            return;
        }

        if (int.TryParse(e.Value.ToString(), out var selectedCustomerId))
        {
            customerId = selectedCustomerId;
            if (customerAdvanceAccounts.TryGetValue(selectedCustomerId, out var advanceAccountId))
            {
                accountToCreditId = advanceAccountId;
            }
        }
    }

    private void EnableEdit()
    {
        originalCustomerId = customerId;
        originalReceiptDate = receiptDate;
        originalAccountToDebitId = accountToDebitId;
        originalAmount = amount;
        originalReferenceNo = referenceNo;
        originalPaymentMethod = paymentMethod;
        originalMemo = memo;
        isEditing = true;
    }

    private void CancelEdit()
    {
        customerId = originalCustomerId;
        receiptDate = originalReceiptDate;
        accountToDebitId = originalAccountToDebitId;
        amount = originalAmount;
        referenceNo = originalReferenceNo;
        paymentMethod = originalPaymentMethod;
        memo = originalMemo;
        // Re-resolve credit account from customer
        if (customerAdvanceAccounts.TryGetValue(customerId, out var advanceAccountId))
        {
            accountToCreditId = advanceAccountId;
        }
        isEditing = false;
        errorMessage = "";
    }

    private async Task HandleSubmit()
    {
        try
        {
            string apiurl = System.Environment.GetEnvironmentVariable("APIURL") ?? "http://localhost:8001/api/";

            // Ensure credit account is set from customer prepayment (silent field — API requires it)
            if (accountToCreditId == 0 && customerAdvanceAccounts.TryGetValue(customerId, out var advanceAccountId))
            {
                accountToCreditId = advanceAccountId;
            }

            var payload = new
            {
                Id = receiptId,
                CustomerId = customerId,
                ReceiptDate = receiptDate,
                Amount = amount,
                AccountToDebitId = accountToDebitId,
                AccountToCreditId = accountToCreditId,
                ReferenceNo = referenceNo,
                PaymentMethod = paymentMethod,
                Memo = memo
            };

            var client = ClientFactory.CreateClient();
            var json = JsonSerializer.Serialize(payload);
            var content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");

            var response = await client.PostAsync($"{apiurl}sales/updatereceipt", content);

            if (response.IsSuccessStatusCode)
            {
                isEditing = false;
                await LoadPayment();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to save payment. Status: {response.StatusCode}. {errorContent}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving payment: {ex.Message}";
        }
    }

    private int? GetJsonInt(JsonElement elem, string propName)
    {
        if (elem.TryGetProperty(propName, out var prop))
        {
            if (prop.ValueKind == JsonValueKind.Number && prop.TryGetInt32(out var val))
                return val;
        }
        return null;
    }

    private decimal? GetJsonDecimal(JsonElement elem, string propName)
    {
        if (elem.TryGetProperty(propName, out var prop))
        {
            if (prop.ValueKind == JsonValueKind.Number && prop.TryGetDecimal(out var val))
                return val;
        }
        return null;
    }

    private string GetJsonPropertyString(JsonElement element, string propertyName)
    {
        if (element.TryGetProperty(propertyName, out var property))
        {
            if (property.ValueKind == JsonValueKind.String)
            {
                return property.GetString() ?? "";
            }
            else if (property.ValueKind == JsonValueKind.Number)
            {
                return property.GetInt32().ToString();
            }
        }
        return "";
    }
}
