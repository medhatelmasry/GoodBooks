@using System.Text.Json
@using System.Text.Json.Serialization
@using AccountGoWeb.Models
@using AccountGoWeb.Models.Sales
@using Microsoft.AspNetCore.Components

<style>
    label,
    h5 {
        color: #fff !important;
    }

    div.row {
        color: #fff;
    }
</style>

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col text-end">
            <a href="/Sales/CustomerPayments" class="btn btn-outline-secondary">
                <i class="fa fa-arrow-left"></i>
                Back to Customer Payments
            </a>
        </div>
    </div>

    @if (loading)
    {
        <p><em>Loading...</em></p>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            <strong>Error:</strong> @errorMessage
        </div>
    }
    else
    {
        <form @onsubmit="HandleSubmit">
            <div class="col-sm-8">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger" role="alert">
                        <strong>Error:</strong> @errorMessage
                    </div>
                }
                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="alert alert-success" role="alert">
                        <i class="fa fa-check-circle"></i> @successMessage
                    </div>
                }
                <div class="card">
                    <div class="card-body">
                        @* Row 1: Received From | Customer Balance | Date *@
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Received From</label>
                            <div class="col-sm-9">
                                <select
                                    class="form-control bg-dark text-white @(string.IsNullOrEmpty(customerId?.ToString()) && submitAttempted ? "is-invalid" : "")"
                                    value="@(customerId?.ToString() ?? string.Empty)"
                                    @onchange="OnCustomerChanged">
                                    <option value="">-- Select Customer --</option>
                                    @foreach (var customer in customers)
                                    {
                                        <option value="@customer.Value">@customer.Text</option>
                                    }
                                </select>
                                @if (string.IsNullOrEmpty(customerId?.ToString()) && submitAttempted)
                                {
                                    <div class="invalid-feedback d-block">Customer is required</div>
                                }
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Customer Balance</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control bg-dark text-white"
                                    value="@customerBalance.ToString("F2")" readonly />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Date</label>
                            <div class="col-sm-9">
                                <input type="date" class="form-control bg-dark text-white" @bind="receiptDate" />
                            </div>
                        </div>

                        @* Row 2: Payment Amount | Reference # | Payment Method *@
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Payment Amount</label>
                            <div class="col-sm-9">
                                <input type="number" step="0.01"
                                    class="form-control bg-dark text-white @(amount <= 0 && submitAttempted ? "is-invalid" : "")"
                                    @bind="amount" placeholder="0.0" />
                                @if (amount <= 0 && submitAttempted)
                                {
                                    <div class="invalid-feedback d-block">Amount must be greater than 0</div>
                                }
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Reference #</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control bg-dark text-white"
                                    @bind="referenceNo" placeholder="Payment reference..." />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Payment Method</label>
                            <div class="col-sm-9">
                                <select class="form-control bg-dark text-white" @bind="paymentMethod">
                                    <option value="">-- Select Method --</option>
                                    @foreach (var method in paymentMethods)
                                    {
                                        <option value="@method">@method</option>
                                    }
                                </select>
                            </div>
                        </div>

                        @* Row 3: Deposit To *@
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Deposit To</label>
                            <div class="col-sm-9">
                                <select
                                    class="form-control bg-dark text-white @(string.IsNullOrEmpty(accountToDebitId?.ToString()) && submitAttempted ? "is-invalid" : "")"
                                    @bind="accountToDebitId">
                                    <option value="">-- Select Bank --</option>
                                    @foreach (var account in debitAccounts)
                                    {
                                        <option value="@account.Value">@account.Text</option>
                                    }
                                </select>
                                @if (string.IsNullOrEmpty(accountToDebitId?.ToString()) && submitAttempted)
                                {
                                    <div class="invalid-feedback d-block">Deposit account is required</div>
                                }
                            </div>
                        </div>

                        @* Memo *@
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Memo</label>
                            <div class="col-sm-9">
                                <textarea class="form-control bg-dark text-white" @bind="memo" rows="2"
                                    placeholder="Optional memo..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-9 mt-3">
                <button id="btnSaveClose" class="btn btn-sm btn-primary btn-flat me-2" type="submit">
                    <i class="fa fa-save"></i> Save &amp; Close
                </button>
                <button id="btnSaveNew" class="btn btn-sm btn-success btn-flat me-2" type="button" @onclick="SaveAndNew">
                    <i class="fa fa-plus"></i> Save &amp; New
                </button>
                <button id="btnClear" class="btn btn-sm btn-outline-light btn-flat me-2" type="button" @onclick="ClearForm">
                    <i class="fa fa-eraser"></i> Clear
                </button>
                <a href="/Sales/CustomerPayments" class="btn btn-sm btn-default btn-flat">Close</a>
            </div>
        </form>
    }
</div>

@code {
    private bool loading = true;
    private string errorMessage = "";
    private bool submitAttempted = false;
    private int? customerId = null;
    private decimal customerBalance = 0;
    private DateTime receiptDate = DateTime.Now;
    private int? accountToDebitId = null;
    private int? accountToCreditId = null; // silently populated from customer's prepayment account
    private decimal amount = 0;
    private string referenceNo = "";
    private string paymentMethod = "";
    private string memo = "";
    private string successMessage = "";

    private readonly List<string> paymentMethods = new()
    {
        "Cash",
        "Cheque",
        "Credit Card",
        "Debit Card",
        "E-Transfer"
    };

    private List<(string Text, string Value)> customers = new();
    private List<(string Text, string Value)> debitAccounts = new();
    private Dictionary<int, int> customerAdvanceAccounts = new();
    private Dictionary<int, decimal> customerBalances = new();

    [Inject]
    private IHttpClientFactory ClientFactory { get; set; } = null!;

    [Inject]
    private NavigationManager Navigation { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            string apiurl = System.Environment.GetEnvironmentVariable("APIURL") ?? "http://localhost:8001/api/";
            var client = ClientFactory.CreateClient();
            client.Timeout = TimeSpan.FromSeconds(60);

            // Load customers (including balance + prepayment account)
            var customersResponse = await client.GetAsync($"{apiurl}sales/customers");
            if (customersResponse.IsSuccessStatusCode)
            {
                var json = await customersResponse.Content.ReadAsStringAsync();
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var customersData = JsonSerializer.Deserialize<List<JsonElement>>(json, options);
                if (customersData != null)
                {
                    foreach (var customer in customersData)
                    {
                        var id = GetJsonPropertyString(customer, "id");
                        var name = GetJsonPropertyString(customer, "name");
                        var prepaymentAccountId = GetJsonPropertyString(customer, "prepaymentAccountId");
                        customers.Add((name ?? "Unknown", id));

                        if (int.TryParse(id, out var cid))
                        {
                            if (int.TryParse(prepaymentAccountId, out var accId))
                            {
                                customerAdvanceAccounts[cid] = accId;
                            }

                            // Get balance
                            if (customer.TryGetProperty("balance", out var balProp) && balProp.TryGetDecimal(out var bal))
                            {
                                customerBalances[cid] = bal;
                            }
                        }
                    }
                }
            }

            // Load cash/bank accounts (Deposit To dropdown)
            var debitResponse = await client.GetAsync($"{apiurl}financials/CashBanks");
            if (debitResponse.IsSuccessStatusCode)
            {
                var json = await debitResponse.Content.ReadAsStringAsync();
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var accountsData = JsonSerializer.Deserialize<List<JsonElement>>(json, options);
                if (accountsData != null)
                {
                    foreach (var account in accountsData)
                    {
                        var id = GetJsonPropertyString(account, "id");
                        var name = GetJsonPropertyString(account, "name");
                        debitAccounts.Add((name ?? "Unknown", id));
                    }
                }
            }

            loading = false;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load form data: {ex.Message}";
            loading = false;
        }
    }

    private void OnCustomerChanged(ChangeEventArgs e)
    {
        if (e.Value == null || string.IsNullOrEmpty(e.Value.ToString()))
        {
            customerId = null;
            accountToCreditId = null;
            customerBalance = 0;
            return;
        }

        if (int.TryParse(e.Value.ToString(), out var selectedCustomerId))
        {
            customerId = selectedCustomerId;

            // Silently populate the credit account (customer's prepayment account)
            // — the API requires AccountToCreditId to match customer.CustomerAdvancesAccountId,
            //   but the instructor does not want this exposed in the UI.
            if (customerAdvanceAccounts.TryGetValue(selectedCustomerId, out var advanceAccountId))
            {
                accountToCreditId = advanceAccountId;
            }

            // Display customer balance
            if (customerBalances.TryGetValue(selectedCustomerId, out var bal))
            {
                customerBalance = bal;
            }
            else
            {
                customerBalance = 0;
            }
        }
    }

    // HandleSubmit is called by form submit (the default "Save & Close" button)
    private async Task HandleSubmit()
    {
        await SavePayment(stayOnForm: false);
    }

    private async Task SaveAndNew()
    {
        await SavePayment(stayOnForm: true);
    }

    private async Task SavePayment(bool stayOnForm)
    {
        submitAttempted = true;
        errorMessage = "";
        successMessage = "";

        // Validate form
        if (string.IsNullOrEmpty(customerId?.ToString()) ||
            string.IsNullOrEmpty(accountToDebitId?.ToString()) ||
            amount <= 0)
        {
            return;
        }

        if (!accountToCreditId.HasValue || accountToCreditId <= 0)
        {
            errorMessage = "Selected customer has no prepayment account configured.";
            return;
        }

        try
        {
            string apiurl = System.Environment.GetEnvironmentVariable("APIURL") ?? "http://localhost:8001/api/";
            var client = ClientFactory.CreateClient();

            // Build payload. API persists PaymentMethod, ReferenceNo, Memo to SalesReceiptHeader.
            var receiptData = new
            {
                CustomerId = customerId!.Value,
                ReceiptDate = receiptDate,
                AccountToDebitId = accountToDebitId!.Value,
                AccountToCreditId = accountToCreditId!.Value,
                Amount = amount,
                PaymentMethod = paymentMethod,
                ReferenceNo = referenceNo,
                Memo = string.IsNullOrWhiteSpace(memo) ? null : memo
            };

            var json = System.Text.Json.JsonSerializer.Serialize(receiptData);
            var content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");

            var response = await client.PostAsync($"{apiurl}sales/savereceipt", content);

            if (response.IsSuccessStatusCode)
            {
                if (stayOnForm)
                {
                    successMessage = "Payment saved. Enter another.";
                    ResetFormFields();
                }
                else
                {
                    Navigation.NavigateTo("/Sales/CustomerPayments", forceLoad: true);
                }
            }
            else
            {
                var responseContent = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to save customer payment. Status: {response.StatusCode}. Details: {responseContent}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving customer payment: {ex.Message}";
        }
    }

    private void ClearForm()
    {
        ResetFormFields();
        errorMessage = "";
        successMessage = "";
    }

    private void ResetFormFields()
    {
        customerId = null;
        customerBalance = 0;
        receiptDate = DateTime.Now;
        accountToDebitId = null;
        accountToCreditId = null;
        amount = 0;
        referenceNo = "";
        paymentMethod = "";
        memo = "";
        submitAttempted = false;
    }

    private string GetJsonPropertyString(JsonElement element, string propertyName)
    {
        if (element.TryGetProperty(propertyName, out var property))
        {
            if (property.ValueKind == JsonValueKind.String)
            {
                return property.GetString() ?? "";
            }
            else if (property.ValueKind == JsonValueKind.Number)
            {
                return property.GetInt32().ToString();
            }
        }
        return "";
    }
}
