@rendermode InteractiveServer

<PageTitle>Payments</PageTitle>

@using System.Text.Json
@using System.Text.Json.Serialization
@inject IHttpClientFactory ClientFactory
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<style>
    .payment-form-row {
        display: flex;
        gap: 20px;
        align-items: flex-end;
    }
    .form-group {
        margin-bottom: 0;
    }
</style>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <strong>SELECT BILLS TO BE PAID</strong>
            </div>
            <div class="card-body">
                @if (getError)
                {
                    <div class="alert alert-danger" role="alert">
                        Unable to get data. Please try again later.
                    </div>
                }
                else if (purchaseInvoices is null)
                {
                    <p><em>Loading...</em></p>
                }
                else
                {
                    <div class="mb-3 d-flex align-items-center">
                        <div class="mr-4">
                            <span>Show bills</span><br/>
                            <input type="radio" id="dueOnOrBefore" name="showBills" value="due" @onchange="@(e => ShowAllBills = false)" checked="@(!ShowAllBills)" />
                            <label for="dueOnOrBefore" class="mr-2">Due on or before</label>
                            <input type="date" @bind="DueDateFilter" class="form-control d-inline-block" style="width: auto;"/>
                            <br/>
                            <input type="radio" id="showAll" name="showBills" value="all" @onchange="@(e => ShowAllBills = true)" checked="@ShowAllBills" />
                            <label for="showAll">Show all bills</label>
                        </div>
                        <div style="margin-left: 20px;">
                            <label>Filter By</label>
                            <select class="form-control">
                                <option>All Vendors</option>
                            </select>
                            <label class="mt-2">Sort By</label>
                            <select class="form-control">
                                <option>Amount Due</option>
                            </select>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th><input type="checkbox" @onchange="ToggleSelectAll" checked="@AllSelected" /></th>
                                    <th>DATE DUE</th>
                                    <th>VENDOR</th>
                                    <th>REF. NO.</th>
                                    <th>DISC. DATE</th>
                                    <th>AMT. DUE</th>
                                    <th>DISC. USED</th>
                                    <th>CREDITS USED</th>
                                    <th>AMT. TO PAY</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var invoice in FilteredInvoices)
                                {
                                    <tr @onclick="() => SelectInvoice(invoice)" class="@(selectedInvoice?.Id == invoice.Id ? "table-active bg-primary text-white" : "")" style="cursor: pointer;">
                                        <td><input type="checkbox" @bind="invoice.Selected" @onclick:stopPropagation="true" /></td>
                                        <td>@invoice.InvoiceDate.ToString("dd-MM-yyyy")</td>
                                        <td>@invoice.VendorName</td>
                                        <td>@invoice.ReferenceNo</td>
                                        <td></td>
                                        <td>@((invoice.Amount - invoice.AmountPaid).ToString("N2"))</td>
                                        <td>0.00</td>
                                        <td>0.00</td>
                                        <td>
                                            @if(invoice.Selected) {
                                                @("$" + (invoice.Amount - invoice.AmountPaid).ToString("N2"))
                                            } else {
                                                @("$0.00")
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="5" class="text-right"><strong>Totals</strong></td>
                                    <td>@("$" + FilteredInvoices.Sum(i => i.Amount - i.AmountPaid).ToString("N2"))</td>
                                    <td>$0.00</td>
                                    <td>$0.00</td>
                                    <td>@("$" + FilteredInvoices.Where(i => i.Selected).Sum(i => i.Amount - i.AmountPaid).ToString("N2"))</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <button class="btn btn-secondary mb-4 mt-2" @onclick="ClearSelections">Clear Selections</button>

                    <div class="card mb-4">
                        <div class="card-header">
                            <strong>CREDIT INFORMATION FOR HIGHLIGHTED BILL</strong>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-4">
                                    <p><strong>Vendor:</strong> @(selectedInvoice?.VendorName ?? "")</p>
                                    <p><strong>Bill Ref. No.:</strong> @(selectedInvoice?.ReferenceNo ?? "")</p>
                                    <button class="btn btn-outline-secondary btn-sm" disabled="@(selectedInvoice == null)">Go to Bill</button>
                                </div>
                                <div class="col-md-4">
                                    <p><strong>Terms:</strong> </p>
                                    <p><strong>Sugg. Discount:</strong> 0.00</p>
                                    <button class="btn btn-outline-secondary btn-sm" disabled>Set Discount</button>
                                </div>
                                <div class="col-md-4">
                                    <p><strong>Number of Credits:</strong> 0</p>
                                    <p><strong>Total Credits Available:</strong> 0.00</p>
                                    <button class="btn btn-outline-secondary btn-sm" disabled>Set Credits</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <strong>PAYMENT</strong>
                        </div>
                        <div class="card-body">
                            <div class="payment-form-row">
                                <div class="form-group">
                                    <label>Date</label>
                                    <input type="date" @bind="PaymentDate" class="form-control" />
                                </div>
                                <div class="form-group">
                                    <label>Method</label>
                                    <select @bind="PaymentMethodId" class="form-control">
                                        <option value="0">-- Select --</option>
                                        @foreach (var method in paymentMethods)
                                        {
                                            <option value="@method.Id">@method.Description</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>Account</label>
                                    <select @bind="PaymentAccountId" class="form-control">
                                        <option value="0">-- Select --</option>
                                        @foreach (var acc in banks)
                                        {
                                            <option value="@acc.Id">@acc.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="mt-3 text-right">
                                <button class="btn btn-primary" @onclick="PaySelectedBills">Pay Selected Bills</button>
                                <button class="btn btn-secondary">Cancel</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<PurchaseInvoiceViewModel>? purchaseInvoices;
    private List<BankDto> banks = new();
    private List<PaymentMethodDto> paymentMethods = new();
    
    private PurchaseInvoiceViewModel? selectedInvoice;
    private bool getError;
    private bool ShowAllBills = true;
    private DateTime DueDateFilter = DateTime.Today;
    
    private DateTime PaymentDate = DateTime.Today;
    private int PaymentMethodId = 0;
    private int PaymentAccountId = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private IEnumerable<PurchaseInvoiceViewModel> FilteredInvoices =>
        ShowAllBills ? purchaseInvoices! : purchaseInvoices!.Where(i => i.InvoiceDate <= DueDateFilter);

    private bool AllSelected
    {
        get => FilteredInvoices.Any() && FilteredInvoices.All(i => i.Selected);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        bool selectAll = (bool)e.Value!;
        foreach (var invoice in FilteredInvoices)
        {
            invoice.Selected = selectAll;
        }
    }

    private void ClearSelections()
    {
        foreach (var invoice in FilteredInvoices)
        {
            invoice.Selected = false;
        }
    }

    private void SelectInvoice(PurchaseInvoiceViewModel invoice)
    {
        selectedInvoice = invoice;
    }

    private async Task LoadData()
    {
        try
        {
            string apiurl = System.Environment.GetEnvironmentVariable("APIURL") ?? "http://localhost:8001/api/";
            var client = ClientFactory.CreateClient();
            client.DefaultRequestHeaders.Accept.Clear();

            // Load Invoices
            var response = await client.GetAsync($"{apiurl}purchasing/purchaseinvoices");
            if (response.IsSuccessStatusCode)
            {
                var responseString = await response.Content.ReadAsStringAsync();
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var invoicesDto = JsonSerializer.Deserialize<List<PurchaseInvoiceDto>>(responseString, options);
                
                purchaseInvoices = invoicesDto!
                    .Where(i => i.Amount - i.AmountPaid > 0)
                    .Select(i => new PurchaseInvoiceViewModel
                    {
                        Id = i.Id,
                        No = i.No,
                        VendorId = i.VendorId,
                        VendorName = i.VendorName,
                        InvoiceDate = i.InvoiceDate,
                        Amount = i.Amount,
                        AmountPaid = i.AmountPaid,
                        ReferenceNo = i.ReferenceNo,
                        Selected = false
                    }).ToList();
            }
            else
            {
                getError = true;
            }

            // Load Banks
            var banksResponse = await client.GetAsync($"{apiurl}common/cashbanks");
            if (banksResponse.IsSuccessStatusCode)
            {
                var str = await banksResponse.Content.ReadAsStringAsync();
                banks = JsonSerializer.Deserialize<List<BankDto>>(str, new JsonSerializerOptions { PropertyNameCaseInsensitive = true })!;
            }

            // Load Payment Methods
            var methodsResponse = await client.GetAsync($"{apiurl}common/paymentmethods");
            if (methodsResponse.IsSuccessStatusCode)
            {
                var str = await methodsResponse.Content.ReadAsStringAsync();
                paymentMethods = JsonSerializer.Deserialize<List<PaymentMethodDto>>(str, new JsonSerializerOptions { PropertyNameCaseInsensitive = true })!;
            }
            
            // Set default payment method and account
            var etransfer = paymentMethods.FirstOrDefault(m => m.Description == "E-Transfer");
            if (etransfer != null) PaymentMethodId = etransfer.Id;
            var firstBank = banks.FirstOrDefault();
            if (firstBank != null) PaymentAccountId = firstBank.Id;
        }
        catch (Exception)
        {
            getError = true;
        }
    }

    private async Task PaySelectedBills()
    {
        var selected = purchaseInvoices!.Where(i => i.Selected).ToList();
        if (!selected.Any())
        {
            await JSRuntime.InvokeVoidAsync("alert", "Please select at least one bill to pay.");
            return;
        }
        if (PaymentAccountId == 0)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Please select an account.");
            return;
        }

        string apiurl = System.Environment.GetEnvironmentVariable("APIURL") ?? "http://localhost:8001/api/";
        var client = ClientFactory.CreateClient();

        foreach (var invoice in selected)
        {
            var paymentDto = new
            {
                InvoiceId = invoice.Id,
                VendorId = invoice.VendorId,
                AccountId = PaymentAccountId,
                AmountToPay = invoice.Amount - invoice.AmountPaid,
                Date = PaymentDate
            };

            var content = new StringContent(JsonSerializer.Serialize(paymentDto), System.Text.Encoding.UTF8, "application/json");
            var response = await client.PostAsync($"{apiurl}purchasing/savepayment", content);
            
            if (!response.IsSuccessStatusCode)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Failed to pay bill {invoice.ReferenceNo}.");
            }
        }
        
        await LoadData();
        StateHasChanged();
    }

    public class PurchaseInvoiceViewModel
    {
        public int Id { get; set; }
        public string? No { get; set; }
        public int VendorId { get; set; }
        public string? VendorName { get; set; }
        public DateTime InvoiceDate { get; set; }
        public decimal Amount { get; set; }
        public decimal AmountPaid { get; set; }
        public string? ReferenceNo { get; set; }
        public bool Selected { get; set; }
    }

    public class PurchaseInvoiceDto
    {
        public int Id { get; set; }
        public string? No { get; set; }
        public int VendorId { get; set; }
        public string? VendorName { get; set; }
        public DateTime InvoiceDate { get; set; }
        public decimal Amount { get; set; }
        public decimal AmountPaid { get; set; }
        public string? ReferenceNo { get; set; }
        public bool Posted { get; set; }
        public bool IsPaid { get; set; }
    }

    public class BankDto
    {
        public int Id { get; set; }
        public string? Name { get; set; }
    }

    public class PaymentMethodDto
    {
        public int Id { get; set; }
        public string? Description { get; set; }
    }
}
