@rendermode InteractiveServer
@using AspNetCoreGeneratedDocument
@using Dto.Donations
@inject HttpClient Http
@inject IConfiguration Configuration
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<style>
    .donationsTable {
        width: 100%;
        border-collapse: collapse;
        background: transparent;
        color: white; /* text visible on dark page */
    }

    .donationsTable th, .donationsTable td {
        padding: 8px;
        text-align: left;
        border: none; /* no borders */
    }

    .donationRow:hover {
        background-color: rgba(255,255,255,0.1);
        cursor: pointer;
    }

    .inactiveLink {
        opacity: 0.5;
        pointer-events: none;
    }

    .badge {
        padding: 0.4rem 0.8rem;
        border-radius: 4px;
        font-weight: 500;
        font-size: 0.75rem;
    }

    .badge-success {
        background: rgba(16, 185, 129, 0.2);
        color: #10b981;
        border: 1px solid rgba(16, 185, 129, 0.3);
    }

    .badge-warning {
        background: rgba(245, 158, 11, 0.2);
        color: #f59e0b;
        border: 1px solid rgba(245, 158, 11, 0.3);
    }

    .loading-container {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 3rem;
    }

.table-donations tbody tr.selected-row td {
        background-color: #007bff33 !important;
        border-left: 3px solid #007bff;
    }
</style>

<PageTitle>Donation Invoices</PageTitle>

<div class="mb-3">
    <a href="/donations/adddonationinvoice" class="btn">
        <i class="fa fa-plus me-1"></i> New Donation Invoice
    </a>
    <button class="btn @(HasSelection ? "" : "inactiveLink")" @onclick="EditInvoice">
        <i class="fa fa-edit me-1"></i> Edit
    </button>
    <button class="btn @(HasSelection ? "" : "inactiveLink")" @onclick="ShowDeleteModal">
        <i class="fa fa-trash me-1"></i> Delete
    </button>
</div>

@if (isLoading)
{
    <div class="loading-container">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (donationInvoices != null && donationInvoices.Any())
{
    <div class="table-container">
        <div class="table-responsive">
            <table class="table table-striped table-bordered table-donations">
                <thead class="thead-dark">
                    <tr>
                        <th style="width: 50px;"></th>
                        <th>Invoice No</th>
                        <th>Donor Name</th>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Purpose</th>
                        <th>Reference No</th>
                        <th>Tax Receipt No</th>
                        <th>Tax Receipt</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var invoice in donationInvoices)
                    {
                        <tr class="@(selectedInvoice?.Id == invoice.Id ? "selected-row" : "")"
                            @onclick="() => SelectInvoice(invoice)"
                            @ondblclick="() => NavigateToDonationInvoice(invoice)"
                            style="cursor: pointer;">
                            <td class="text-center">
                                <input type="radio" name="selectedInvoice" checked="@(selectedInvoice?.Id == invoice.Id)" />
                            </td>
                            <td><strong>@invoice.No</strong></td>
                            <td>@invoice.DonorName</td>
                            <td>@invoice.DonationDate.ToString("MMM dd, yyyy")</td>
                            <td><strong class="text-success">$@invoice.Amount.ToString("F2")</strong></td>
                            <td>@invoice.Purpose</td>
                            <td>@invoice.ReferenceNo</td>
                            <td>@invoice.TaxReceiptNo</td>
                            <td class="text-center">
                                @if (invoice.IsTaxReceiptIssued)
                                {
                                    <span class="badge badge-success">
                                        <i class="fa fa-check"></i> Issued
                                    </span>
                                }
                                else
                                {
                                    <span class="badge badge-warning">
                                        <i class="fa fa-clock"></i> Pending
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                @if (invoice.Posted)
                                {
                                    <span class="badge badge-success">
                                        <i class="fa fa-check"></i> Posted
                                    </span>
                                }
                                else
                                {
                                    <span class="badge badge-warning">
                                        <i class="fa fa-clock"></i> Draft
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div>
        <table class="donationsTable">
            <thead>
                <tr>
                    <th>Invoice No</th>
                    <th>Donor Name</th>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Purpose</th>
                    <th>Reference No</th>
                    <th>Tax Receipt No</th>
                    <th>Tax Receipt</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var invoice in donationInvoices)
                {
                    <tr class="donationRow @(selectedInvoice?.Id == invoice.Id ? "table-active" : "")"
                        @onclick="() => SelectInvoice(invoice)">
                        <td><strong>@invoice.No</strong></td>
                        <td>@invoice.DonorName</td>
                        <td>@invoice.DonationDate.ToString("MMM dd, yyyy")</td>
                        <td><strong class="text-success">$@invoice.Amount.ToString("F2")</strong></td>
                        <td>@invoice.Purpose</td>
                        <td>@invoice.ReferenceNo</td>
                        <td>@invoice.TaxReceiptNo</td>
                        <td>
                            @if (invoice.IsTaxReceiptIssued)
                            {
                                <span class="badge badge-success">Issued</span>
                            }
                            else
                            {
                                <span class="badge badge-warning">Pending</span>
                            }
                        </td>
                        <td>
                            @if (invoice.Posted)
                            {
                                <span class="badge badge-success">Posted</span>
                            }
                            else
                            {
                                <span class="badge badge-warning">Draft</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@* Delete Confirmation Modal *@
@if (showDeleteModal)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content bg-dark text-white shadow">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title">Delete Donation Invoice</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDeleteModal"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this donation invoice?</p>
                    @if (selectedInvoice != null)
                    {
                        <div class="small text-secondary">
                            <div><strong>Invoice No:</strong> @selectedInvoice.No</div>
                            <div><strong>Donor:</strong> @selectedInvoice.DonorName</div>
                            <div><strong>Amount:</strong> @selectedInvoice.Amount.ToString("C2")</div>
                        </div>
                    }
                </div>
                <div class="modal-footer border-secondary">
                    <button class="btn btn-danger" @onclick="DeleteInvoice">Yes, Delete</button>
                    <button class="btn btn-secondary" @onclick="CloseDeleteModal">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<DonationInvoice>? donationInvoices;
    private DonationInvoice? selectedInvoice;
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private bool HasSelection => selectedInvoice != null;

    protected override async Task OnInitializedAsync()
    {
        await LoadDonationInvoices();
    }

    private async Task LoadDonationInvoices()
    {
        isLoading = true;
        try
        {
            var apiUrl = Configuration["ApiUrl"];
            var response = await Http.GetAsync($"{apiUrl}donations/donationinvoices");

            if (response.IsSuccessStatusCode)
            {
                var responseJson = await response.Content.ReadAsStringAsync();
                donationInvoices = System.Text.Json.JsonSerializer.Deserialize<List<DonationInvoice>>(
                    responseJson,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }
                );
            }
            else
            {
                donationInvoices = new List<DonationInvoice>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading donation invoices: {ex.Message}");
            donationInvoices = new List<DonationInvoice>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SelectInvoice(DonationInvoice invoice)
    {
        selectedInvoice = invoice;
    }

    private void NavigateToDonationInvoice(DonationInvoice invoice) 
    {
        SelectInvoice(invoice);
        if (selectedInvoice != null)
        {
            NavigationManager.NavigateTo($"/donations/donationinvoice/{selectedInvoice.Id}", forceLoad: true);
        }
    }

    private void EditInvoice()
    {
        if (selectedInvoice != null)
        {
            NavigationManager.NavigateTo($"/donations/donationinvoice/{selectedInvoice.Id}", forceLoad: true);
        }
    }

    private void ShowDeleteModal()
    {
        if (selectedInvoice != null)
        {
            showDeleteModal = true;
        }
    }

    private void CloseDeleteModal()
    {
        showDeleteModal = false;
    }

    private async Task DeleteInvoice()
    {
        if (selectedInvoice != null)
        {
            try
            {
                NavigationManager.NavigateTo($"/donations/deletedonationinvoice/{selectedInvoice.Id}");
                showDeleteModal = false;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting invoice: {ex.Message}");
            }
        }
    }
}
